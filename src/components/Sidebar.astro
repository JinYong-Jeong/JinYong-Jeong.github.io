---
import { ArrowRight, BriefcaseBusiness, GitFork, Mail, MapPin } from "@lucide/astro";
import { site } from "@/config/site";
import { getProjectUrl, type Project } from "@/lib/content";

interface Props {
  projects: Project[];
  variant?: "shell" | "cards" | "home";
}

const { projects, variant = "cards" } = Astro.props;
const iconMap = { github: GitFork, mail: Mail, linkedin: BriefcaseBusiness };
const contactLinks = site.socials;
const sidebarTechStack = site.techStack.slice(0, 8);
const sidebarTopics = [
  ...Object.values(site.categories).map((category) => category.label),
  "LoRA",
  "Evaluation",
  "MLOps"
];
const isCardStack = variant === "cards";
const isHomeStack = variant === "home";
const useCardStack = isCardStack || isHomeStack;
const sectionClass = useCardStack ? "home-sidebar-card surface-section" : "surface-section";
---

<aside
  class:list={[
    useCardStack
      ? "home-sidebar-stack lg:sticky lg:top-24 lg:self-start"
      : "surface-main sidebar-shell lg:sticky lg:top-24 lg:self-start"
  ]}
>
  <section class={sectionClass}>
    <h2 class="mb-5 text-lg font-bold tracking-normal">
      <a class="focus-ring inline-flex items-center gap-2 hover:text-[var(--color-accent)]" href="/about/">
        About Me
        <ArrowRight size={15} stroke-width={1.8} />
      </a>
    </h2>
    <div class="flex gap-4">
      <img
        src={site.author.avatar}
        alt={`${site.author.displayName} avatar`}
        class="size-20 shrink-0 rounded-[1rem] border border-[var(--color-border)] object-cover"
        loading="lazy"
        referrerpolicy="no-referrer"
      />
      <div class="min-w-0">
        <p class="font-semibold">{site.author.displayName}입니다.</p>
        <p class="mt-2 text-sm leading-7 text-[var(--color-muted)]">{site.author.bio}</p>
      </div>
    </div>
    <div class="sidebar-contact-list mt-5">
      <span>
        <MapPin size={16} stroke-width={1.8} />
        {site.author.location}
      </span>
      {
        contactLinks.map((link) => {
          const Icon = iconMap[link.icon as keyof typeof iconMap];
          return (
            <a class="focus-ring" href={link.href}>
              <Icon size={16} stroke-width={1.8} />
              {link.label}
            </a>
          );
        })
      }
    </div>
  </section>

  {!isHomeStack && <section class={sectionClass}>
    <h2 class="mb-5 text-lg font-bold tracking-normal">{useCardStack ? "Topics" : "Tech Stack"}</h2>
    {
      useCardStack ? (
        <div class="flex flex-wrap gap-2">
          {sidebarTopics.map((topic) => <span class="chip">{topic}</span>)}
        </div>
      ) : (
        <ul class="sidebar-tech-list">
          {
            sidebarTechStack.map((tech) => (
              <li>
                <span class="sidebar-tech-dot"></span>
                <span class="truncate">{tech}</span>
              </li>
            ))
          }
        </ul>
      )
    }
  </section>}

  {!isHomeStack && <section class={sectionClass}>
    <div class="mb-5 flex items-center justify-between gap-3">
      <h2 class="text-lg font-bold tracking-normal">Recent Projects</h2>
      <a class="focus-ring text-sm font-semibold text-[var(--color-accent)] hover:underline" href="/projects/">
        All
      </a>
    </div>
    <div class="content-list">
      {
        projects.slice(0, 3).map((project) => (
          <a class="focus-ring flex items-start gap-3 py-3 first:pt-0 last:pb-0 hover:text-[var(--color-accent)]" href={getProjectUrl(project)}>
            <span class="rail-label mt-0.5 shrink-0">{project.data.title.slice(0, 1)}</span>
            <span class="min-w-0 flex-1">
              <span class="block truncate text-sm font-semibold text-[var(--color-text)]">{project.data.title}</span>
              <span class="mt-1 block truncate text-sm text-[var(--color-muted)]">{project.data.description}</span>
            </span>
            <ArrowRight class="mt-0.5 shrink-0 text-[var(--color-accent)]" size={15} />
          </a>
        ))
      }
    </div>
  </section>}

</aside>
