---
import { ArrowRight, BriefcaseBusiness, GitBranch, Mail, Rss } from "@lucide/astro";
import { site } from "@/config/site";
import { getProjectUrl, type Project } from "@/lib/content";

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
const iconMap = { github: GitBranch, mail: Mail, linkedin: BriefcaseBusiness, rss: Rss };
---

<aside class="space-y-4 lg:sticky lg:top-24">
  <section class="panel p-5">
    <h2 class="mb-4 text-lg font-bold tracking-normal">About Me</h2>
    <div class="flex gap-4">
      <div class="flex size-20 shrink-0 items-center justify-center rounded-3xl border border-[var(--color-border)] bg-[linear-gradient(135deg,#f3e3d5,#d8b49a)] text-2xl font-black text-[var(--color-accent)]">
        {site.shortName}
      </div>
      <div>
        <p class="font-semibold">{site.author.displayName}입니다.</p>
        <p class="mt-2 text-sm leading-7 text-[var(--color-muted)]">{site.author.bio}</p>
      </div>
    </div>
    <div class="mt-5 flex flex-wrap gap-2">
      {site.focusAreas.map((item) => <span class="chip">{item}</span>)}
    </div>
  </section>

  <section class="panel p-5">
    <h2 class="mb-4 text-lg font-bold tracking-normal">Tech Stack</h2>
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-2 xl:grid-cols-3">
      {
        site.techStack.map((tech) => (
          <div class="panel-subtle flex min-h-20 flex-col items-center justify-center gap-2 p-3 text-center">
            <span class="flex size-8 items-center justify-center rounded-xl bg-[var(--color-surface-soft)] text-sm font-black text-[var(--color-accent)]">
              {tech.slice(0, 2)}
            </span>
            <span class="text-xs font-medium text-[var(--color-muted)]">{tech}</span>
          </div>
        ))
      }
    </div>
  </section>

  <section class="panel p-5">
    <h2 class="mb-4 text-lg font-bold tracking-normal">Recent Projects</h2>
    <div class="space-y-2">
      {
        projects.map((project) => (
          <a class="focus-ring group flex items-center gap-3 rounded-xl p-2 transition-colors hover:bg-[var(--color-surface-soft)]" href={getProjectUrl(project)}>
            <span class="flex size-9 shrink-0 items-center justify-center rounded-lg border border-[var(--color-border)] text-xs font-black text-[var(--color-accent)]">
              {project.data.title.slice(0, 1)}
            </span>
            <span class="min-w-0 flex-1">
              <span class="block truncate text-sm font-semibold">{project.data.title}</span>
              <span class="block truncate text-xs text-[var(--color-muted)]">{project.data.description}</span>
            </span>
            <ArrowRight class="text-[var(--color-accent)] transition-transform group-hover:translate-x-0.5" size={16} />
          </a>
        ))
      }
    </div>
    <a class="focus-ring mt-4 flex justify-center rounded-xl bg-[var(--color-surface-soft)] px-4 py-2 text-sm font-semibold text-[var(--color-accent)] hover:bg-[#efe2d7]" href="/projects/">
      모든 프로젝트 보기 →
    </a>
  </section>

  <section class="panel p-5">
    <h2 class="mb-4 text-lg font-bold tracking-normal">Links</h2>
    <div class="grid grid-cols-2 gap-3">
      {
        site.socials.map((link) => {
          const Icon = iconMap[link.icon as keyof typeof iconMap];
          return (
            <a class="focus-ring panel-subtle flex min-h-20 flex-col items-center justify-center gap-2 p-3 text-sm font-medium text-[var(--color-muted)] hover:text-[var(--color-accent)]" href={link.href}>
              <Icon size={22} stroke-width={1.8} />
              {link.label}
            </a>
          );
        })
      }
    </div>
  </section>
</aside>
