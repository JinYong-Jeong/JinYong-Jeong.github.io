---
import ResearchVisual from "@/components/ResearchVisual.astro";
import TagList from "@/components/TagList.astro";
import { site, type CategoryKey } from "@/config/site";
import { estimateReadingMinutes, formatDate, getPostUrl, type Post } from "@/lib/content";

interface Props {
  post: Post;
  visual?: boolean;
  variant?: "tile" | "row";
}

const { post, visual = true, variant = "tile" } = Astro.props;
const category = post.data.category as CategoryKey;
---

{
  variant === "row" ? (
    <article class="grid gap-5 py-6 md:grid-cols-[210px_minmax(0,1fr)] md:items-start">
      {visual && <ResearchVisual category={category} compact={true} />}
      <div class="min-w-0">
        <div class="mb-3 flex flex-wrap items-center gap-2 text-xs text-[var(--color-muted)]">
          <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
          <span aria-hidden="true">·</span>
          <a class="chip focus-ring" href={`/blog/category/${category}/`}>
            {site.categories[category].label}
          </a>
        </div>
        <h3 class="text-[1.65rem] font-bold leading-[1.25] tracking-normal text-[var(--color-text)]">
          <a class="focus-ring rounded-sm hover:text-[var(--color-accent)]" href={getPostUrl(post)}>
            {post.data.title}
          </a>
        </h3>
        <p class="mt-3 max-w-3xl text-[15px] leading-8 text-[var(--color-muted)]">{post.data.description}</p>
        <div class="mt-5 flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
          <span class="text-sm text-[var(--color-subtle)]">{estimateReadingMinutes(post.body)} min read</span>
          <TagList tags={post.data.tags.slice(0, 4)} />
        </div>
      </div>
    </article>
  ) : (
    <article class="group h-full">
      {visual && <ResearchVisual category={category} compact={true} />}
      <div class="pt-4">
        <div class="mb-3 flex flex-wrap items-center gap-2 text-xs text-[var(--color-muted)]">
          <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
          <span aria-hidden="true">·</span>
          <a class="chip focus-ring" href={`/blog/category/${category}/`}>
            {site.categories[category].label}
          </a>
        </div>
        <h3 class="text-[1.55rem] font-bold leading-[1.28] tracking-normal text-[var(--color-text)]">
          <a class="focus-ring rounded-sm group-hover:text-[var(--color-accent)]" href={getPostUrl(post)}>
            {post.data.title}
          </a>
        </h3>
        <p class="mt-3 text-sm leading-7 text-[var(--color-muted)]">{post.data.description}</p>
        <div class="mt-5 flex flex-col gap-4">
          <span class="text-xs text-[var(--color-subtle)]">{estimateReadingMinutes(post.body)} min read</span>
          <TagList tags={post.data.tags.slice(0, 3)} />
        </div>
      </div>
    </article>
  )
}
