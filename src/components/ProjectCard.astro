---
import ProjectVisual from "@/components/ProjectVisual.astro";
import { ExternalLink } from "@lucide/astro";
import type { Project } from "@/lib/content";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article
  id={project.id}
  class="panel-subtle scroll-mt-24 overflow-hidden transition-transform duration-200 hover:-translate-y-0.5 hover:shadow-[var(--shadow-card)]"
>
  <ProjectVisual project={project} />
  <div class="p-5">
    <div class="mb-3 flex flex-wrap items-center gap-2">
      <h3 class="text-lg font-bold tracking-normal">{project.data.title}</h3>
      <span class="chip">{project.data.status}</span>
    </div>
    <p class="text-sm leading-7 text-[var(--color-muted)]">{project.data.description}</p>
    <div class="mt-4 flex flex-wrap gap-2">
      {project.data.techStack.map((tech) => <span class="chip">{tech}</span>)}
    </div>
    {
      project.data.links.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-3">
          {project.data.links.map((link) => (
            <a class="focus-ring inline-flex items-center gap-1 text-sm font-semibold text-[var(--color-accent)] hover:underline" href={link.href}>
              {link.label}
              <ExternalLink size={14} />
            </a>
          ))}
        </div>
      )
    }
  </div>
</article>
