---
import ProjectVisual from "@/components/ProjectVisual.astro";
import { ExternalLink } from "@lucide/astro";
import type { Project } from "@/lib/content";

interface Props {
  project: Project;
  variant?: "tile" | "row";
}

const { project, variant = "tile" } = Astro.props;
---

{
  variant === "row" ? (
    <article id={project.id} class="grid gap-5 py-6 md:grid-cols-[210px_minmax(0,1fr)] md:items-start">
      <ProjectVisual project={project} compact={true} />
      <div class="min-w-0">
        <div class="mb-3 flex flex-wrap items-center gap-2">
          <h3 class="text-[1.45rem] font-bold leading-[1.25] tracking-normal text-[var(--color-text)]">{project.data.title}</h3>
          <span class="chip">{project.data.status}</span>
        </div>
        <p class="max-w-3xl text-[15px] leading-8 text-[var(--color-muted)]">{project.data.description}</p>
        <div class="mt-5 flex flex-wrap gap-2">
          {project.data.techStack.map((tech) => <span class="chip">{tech}</span>)}
        </div>
        {
          project.data.links.length > 0 && (
            <div class="mt-5 flex flex-wrap gap-4">
              {project.data.links.map((link) => (
                <a class="focus-ring inline-flex items-center gap-1 text-sm font-semibold text-[var(--color-accent)] hover:underline" href={link.href}>
                  {link.label}
                  <ExternalLink size={14} />
                </a>
              ))}
            </div>
          )
        }
      </div>
    </article>
  ) : (
    <article id={project.id} class="group">
      <ProjectVisual project={project} compact={true} />
      <div class="pt-4">
        <div class="mb-3 flex flex-wrap items-center gap-2">
          <h3 class="text-xl font-bold tracking-normal">{project.data.title}</h3>
          <span class="chip">{project.data.status}</span>
        </div>
        <p class="text-sm leading-7 text-[var(--color-muted)]">{project.data.description}</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {project.data.techStack.map((tech) => <span class="chip">{tech}</span>)}
        </div>
        {
          project.data.links.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-3">
              {project.data.links.map((link) => (
                <a class="focus-ring inline-flex items-center gap-1 text-sm font-semibold text-[var(--color-accent)] hover:underline" href={link.href}>
                  {link.label}
                  <ExternalLink size={14} />
                </a>
              ))}
            </div>
          )
        }
      </div>
    </article>
  )
}
