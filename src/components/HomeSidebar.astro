---
import {
  ArrowRight,
  BriefcaseBusiness,
  GitBranch,
  Mail,
  MapPin,
  Rss
} from "@lucide/astro";
import { site } from "@/config/site";
import { getProjectUrl, type Project } from "@/lib/content";

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
const iconMap = { github: GitBranch, mail: Mail, linkedin: BriefcaseBusiness, rss: Rss };
---

<aside class="home-sidebar" aria-label="Profile and blog summary">
  <section class="home-sidebar-section">
    <header class="flex items-start gap-4">
      <img
        src={site.author.avatar}
        alt={`${site.author.displayName} avatar`}
        class="size-20 shrink-0 rounded-[1.35rem] border border-[var(--color-border)] object-cover"
        loading="lazy"
        referrerpolicy="no-referrer"
      />
      <div class="min-w-0">
        <p class="text-xs font-semibold uppercase tracking-[0.1em] text-[var(--color-subtle)]">About</p>
        <h2 class="mt-2 text-[1.35rem] font-semibold tracking-normal text-[var(--color-text)]">
          {site.author.displayName}
        </h2>
        <p class="mt-2 line-clamp-2 text-sm leading-7 text-[var(--color-muted)]">{site.author.bio}</p>
      </div>
    </header>
    <div class="mt-4 flex items-center gap-2 text-sm text-[var(--color-muted)]">
      <MapPin size={15} stroke-width={1.8} class="text-[var(--color-accent)]" />
      <span>{site.author.location}</span>
    </div>
    <div class="mt-4 flex flex-wrap gap-2">
      {site.focusAreas.slice(0, 2).map((item) => <span class="chip">{item}</span>)}
    </div>
  </section>

  <section class="home-sidebar-section">
    <header class="mb-4">
      <p class="text-xs font-semibold uppercase tracking-[0.1em] text-[var(--color-subtle)]">Tech Stack</p>
      <h2 class="mt-1 text-lg font-semibold tracking-normal text-[var(--color-text)]">Core Tools</h2>
    </header>
    <ul class="home-tech-list">
      {
        site.techStack.slice(0, 6).map((tech) => (
          <li>
            <span class="home-tech-badge">{tech.slice(0, 2)}</span>
            <span>{tech}</span>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="home-sidebar-section">
    <header class="mb-3 flex items-center justify-between gap-3">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.1em] text-[var(--color-subtle)]">Projects</p>
        <h2 class="mt-1 text-lg font-semibold tracking-normal text-[var(--color-text)]">Recent Work</h2>
      </div>
      <a class="focus-ring text-sm font-semibold text-[var(--color-accent)] hover:underline" href="/projects/">
        전체 보기
      </a>
    </header>
    <ul class="home-project-list">
      {
        projects.slice(0, 2).map((project) => (
          <li>
            <a class="focus-ring home-project-link group" href={getProjectUrl(project)}>
              <span class="home-project-mark">{project.data.title.slice(0, 1)}</span>
              <span class="min-w-0 flex-1">
                <span class="block truncate text-sm font-semibold text-[var(--color-text)]">
                  {project.data.title}
                </span>
              </span>
              <ArrowRight
                size={15}
                stroke-width={1.8}
                class="shrink-0 text-[var(--color-accent)] transition-transform group-hover:translate-x-0.5"
              />
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="home-sidebar-section">
    <header class="mb-3">
      <p class="text-xs font-semibold uppercase tracking-[0.1em] text-[var(--color-subtle)]">Links</p>
      <h2 class="mt-1 text-lg font-semibold tracking-normal text-[var(--color-text)]">Stay in Touch</h2>
    </header>
    <nav class="home-link-list" aria-label="External links">
      {
        site.socials.map((link) => {
          const Icon = iconMap[link.icon as keyof typeof iconMap];
          return (
            <a class="focus-ring home-link-item" href={link.href}>
              <Icon size={16} stroke-width={1.8} />
              <span>{link.label}</span>
            </a>
          );
        })
      }
    </nav>
  </section>
</aside>
