---
import { GitFork, Search } from "@lucide/astro";
import { site } from "@/config/site";
import logoImage from "../../engineering/design/logo2.png";

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
const logoSrc = typeof logoImage === "string" ? logoImage : logoImage.src;
---

<header class="site-header sticky top-0 z-30 border-b backdrop-blur-xl">
  <div class="container-page flex h-16 items-center gap-7">
    <a href="/" class="focus-ring flex shrink-0 items-center gap-3" aria-label="Go to home">
      <img class="site-logo" src={logoSrc} alt={`${site.name} logo`} />
    </a>
    <nav class="hidden h-full items-center gap-6 sm:flex" aria-label="Primary navigation">
      {
        site.nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              "focus-ring inline-flex h-full items-center border-b-2 border-transparent px-1 text-sm font-medium transition-colors",
              isActive(item.href)
                ? "border-[var(--color-accent)] text-[var(--color-accent)]"
                : "text-[var(--color-muted)] hover:text-[var(--color-accent)]"
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
    <div class="ml-auto flex items-center gap-3">
      <a
        class="focus-ring inline-flex items-center justify-center text-[var(--color-accent)] transition-colors hover:text-[var(--color-accent-2)]"
        href="/search/"
        aria-label="Search"
      >
        <Search size={18} stroke-width={1.8} />
      </a>
      <a
        class="focus-ring inline-flex items-center justify-center text-[var(--color-accent)] transition-colors hover:text-[var(--color-accent-2)]"
        href="https://github.com/JinYong-Jeong"
        aria-label="GitHub"
      >
        <GitFork size={18} stroke-width={1.8} />
      </a>
    </div>
  </div>
  <nav class="container-page flex gap-2 overflow-x-auto pb-3 sm:hidden" aria-label="Mobile navigation">
    {
      site.nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "focus-ring rounded-full px-3 py-1.5 text-sm font-medium",
            isActive(item.href)
              ? "bg-[var(--color-surface-soft)] text-[var(--color-accent)]"
              : "text-[var(--color-muted)]"
          ]}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
</header>
