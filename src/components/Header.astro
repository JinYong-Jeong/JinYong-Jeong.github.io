---
import { GitBranch, Rss } from "@lucide/astro";
import { site } from "@/config/site";

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header class="sticky top-0 z-30 border-b border-[var(--color-border)] bg-[rgba(250,247,241,0.86)] backdrop-blur-xl">
  <div class="container-page flex h-16 items-center justify-between gap-6">
    <a href="/" class="focus-ring flex items-center gap-3" aria-label="Go to home">
      <span class="text-2xl font-black tracking-normal text-[var(--color-accent)]">{site.shortName}</span>
    </a>
    <nav class="hidden items-center gap-1 sm:flex" aria-label="Primary navigation">
      {
        site.nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              "focus-ring rounded-full px-4 py-2 text-sm font-medium transition-colors",
              isActive(item.href)
                ? "bg-[var(--color-surface-soft)] text-[var(--color-accent)]"
                : "text-[var(--color-muted)] hover:text-[var(--color-accent)]"
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
    <div class="flex items-center gap-2">
      <a
        class="focus-ring inline-flex size-10 items-center justify-center rounded-full text-[var(--color-accent)] transition-colors hover:bg-[var(--color-surface-soft)]"
        href="https://github.com/JinYong-Jeong"
        aria-label="GitHub"
      >
        <GitBranch size={18} stroke-width={1.8} />
      </a>
      <a
        class="focus-ring inline-flex size-10 items-center justify-center rounded-full text-[var(--color-accent)] transition-colors hover:bg-[var(--color-surface-soft)]"
        href="/rss.xml"
        aria-label="RSS"
      >
        <Rss size={18} stroke-width={1.8} />
      </a>
    </div>
  </div>
  <nav class="container-page flex gap-2 overflow-x-auto pb-3 sm:hidden" aria-label="Mobile navigation">
    {
      site.nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "focus-ring rounded-full px-3 py-1.5 text-sm font-medium",
            isActive(item.href)
              ? "bg-[var(--color-surface-soft)] text-[var(--color-accent)]"
              : "text-[var(--color-muted)]"
          ]}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
</header>
