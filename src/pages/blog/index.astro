---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import Sidebar from "@/components/Sidebar.astro";
import TagList from "@/components/TagList.astro";
import { site, type CategoryKey } from "@/config/site";
import { categoryKeys, getAllTags, getCategoryUrl, getFeaturedProjects, getPublishedPosts } from "@/lib/content";

const posts = await getPublishedPosts();
const tags = getAllTags(posts);
const projects = await getFeaturedProjects(3);
---

<BaseLayout title="Blog" description="LLM, Federated Learning, 논문 리뷰, 실험 로그 글 목록입니다.">
  <div class="container-page py-8 lg:py-10">
    <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_320px]">
      <section class="surface-main">
        <header class="surface-section">
          <p class="chip mb-4 w-fit">Research Notes</p>
          <h1 class="text-4xl font-black tracking-normal sm:text-5xl">Blog</h1>
          <p class="mt-4 max-w-3xl text-[15px] leading-8 text-[var(--color-muted)]">
            공부한 개념, 읽은 논문, 실험 결과, 구현하면서 정리한 문제 해결 기록을 모읍니다.
          </p>
          <div class="mt-7 grid gap-3 md:grid-cols-[minmax(0,1fr)_auto]">
            <label class="block">
              <span class="sr-only">검색</span>
              <input
                id="blog-search"
                type="search"
                placeholder="제목, 설명, 태그 검색"
                class="w-full rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-soft)] px-4 py-3.5 text-sm text-[var(--color-text)] outline-none transition-colors placeholder:text-[var(--color-subtle)] focus:border-[var(--color-accent-2)]"
              />
            </label>
            <a class="focus-ring inline-flex items-center justify-center rounded-xl border border-[var(--color-border)] px-4 py-3.5 text-sm font-semibold text-[var(--color-accent)] hover:bg-[var(--color-surface-soft)]" href="/search/">
              전체 검색 페이지 →
            </a>
          </div>
          <p id="blog-search-summary" class="mt-3 text-sm text-[var(--color-muted)]">
            {posts.length}개의 공개 글
          </p>
        </header>

        <section class="surface-divider surface-section">
          <h2 class="text-xl font-bold tracking-normal text-[var(--color-text)]">카테고리</h2>
          <p class="mt-2 text-sm text-[var(--color-muted)]">관심 주제별로 바로 이동합니다.</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {
              categoryKeys.map((category) => (
                <a class="chip focus-ring hover:border-[var(--color-accent-2)]" href={getCategoryUrl(category)}>
                  {site.categories[category as CategoryKey].label}
                </a>
              ))
            }
          </div>
          <div class="mt-5 border-t subtle-divider pt-5">
            <TagList tags={tags} />
          </div>
        </section>

        <section class="surface-divider">
          <div class="surface-section pb-0">
            <h2 class="text-xl font-bold tracking-normal text-[var(--color-text)]">전체 글</h2>
            <p class="mt-2 text-sm text-[var(--color-muted)]">연구 노트와 구현 기록을 시간순으로 정리했습니다.</p>
          </div>
          <div id="blog-post-list" class="content-list">
            {
              posts.map((post) => (
                <div
                  class="surface-section py-0"
                  data-post-card
                  data-search={`${post.data.title} ${post.data.description} ${post.data.tags.join(" ")} ${post.data.category}`.toLowerCase()}
                >
                  <PostCard post={post} variant="row" />
                </div>
              ))
            }
          </div>
        </section>
      </section>

      <Sidebar projects={projects} />
    </div>
  </div>

  <script is:inline>
    const input = document.querySelector("#blog-search");
    const summary = document.querySelector("#blog-search-summary");
    const cards = Array.from(document.querySelectorAll("[data-post-card]"));

    const update = () => {
      const query = String(input?.value || "").trim().toLowerCase();
      let visible = 0;

      for (const card of cards) {
        const searchText = card.getAttribute("data-search") || "";
        const match = !query || searchText.includes(query);
        card.toggleAttribute("hidden", !match);
        if (match) visible += 1;
      }

      if (summary) {
        summary.textContent = query
          ? `"${query}" 검색 결과 ${visible}개`
          : `${cards.length}개의 공개 글`;
      }
    };

    input?.addEventListener("input", update);
  </script>
</BaseLayout>
