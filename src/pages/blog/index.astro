---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import PostCard from "@/components/PostCard.astro";
import Sidebar from "@/components/Sidebar.astro";
import TagList from "@/components/TagList.astro";
import { site, type CategoryKey } from "@/config/site";
import { categoryKeys, getAllTags, getCategoryUrl, getFeaturedProjects, getPublishedPosts } from "@/lib/content";

const posts = await getPublishedPosts();
const tags = getAllTags(posts);
const projects = await getFeaturedProjects(3);
---

<BaseLayout title="Blog" description="LLM, Federated Learning, 논문 리뷰, 실험 로그 글 목록입니다.">
  <div class="container-page page-wrap">
    <div class="page-layout">
      <section class="page-main-panel">
        <PageHero
          kicker="Research Notes"
          title="Blog"
          description="공부한 개념, 읽은 논문, 실험 결과, 구현하면서 정리한 문제 해결 기록을 모읍니다."
        />

        <div class="page-toolbar">
            <label class="block">
              <span class="sr-only">검색</span>
              <input
                id="blog-search"
                type="search"
                placeholder="제목, 설명, 태그 검색"
                class="page-search-input"
              />
            </label>
            <a class="page-toolbar-link focus-ring" href="/search/">
              전체 검색 페이지 →
            </a>
        </div>
        <p id="blog-search-summary" class="page-result-summary">
            {posts.length}개의 공개 글
        </p>

        <section class="filter-panel">
          <div>
            <h2>카테고리</h2>
            <p>관심 주제별로 바로 이동합니다.</p>
          </div>
          <div class="filter-chip-grid">
            {
              categoryKeys.map((category) => (
                <a class="chip focus-ring hover:border-[var(--color-accent-2)]" href={getCategoryUrl(category)}>
                  {site.categories[category as CategoryKey].label}
                </a>
              ))
            }
          </div>
          <div class="filter-tag-row">
            <TagList tags={tags} />
          </div>
        </section>

        <section class="content-card-list" id="blog-post-list">
            {
              posts.map((post) => (
                <div
                  class="content-row-card"
                  data-post-card
                  data-search={`${post.data.title} ${post.data.description} ${post.data.tags.join(" ")} ${post.data.category}`.toLowerCase()}
                >
                  <PostCard post={post} variant="row" />
                </div>
              ))
            }
        </section>
      </section>

      <Sidebar projects={projects} />
    </div>
  </div>

  <script is:inline>
    const input = document.querySelector("#blog-search");
    const summary = document.querySelector("#blog-search-summary");
    const cards = Array.from(document.querySelectorAll("[data-post-card]"));

    const update = () => {
      const query = String(input?.value || "").trim().toLowerCase();
      let visible = 0;

      for (const card of cards) {
        const searchText = card.getAttribute("data-search") || "";
        const match = !query || searchText.includes(query);
        card.toggleAttribute("hidden", !match);
        if (match) visible += 1;
      }

      if (summary) {
        summary.textContent = query
          ? `"${query}" 검색 결과 ${visible}개`
          : `${cards.length}개의 공개 글`;
      }
    };

    input?.addEventListener("input", update);
  </script>
</BaseLayout>
