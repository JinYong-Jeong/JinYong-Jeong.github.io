---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import Sidebar from "@/components/Sidebar.astro";
import { site, type CategoryKey } from "@/config/site";
import { categoryKeys, getFeaturedProjects, getPublishedPosts } from "@/lib/content";

export function getStaticPaths() {
  return categoryKeys.map((category) => ({ params: { category } }));
}

const category = Astro.params.category as CategoryKey;
const posts = (await getPublishedPosts()).filter((post) => post.data.category === category);
const projects = await getFeaturedProjects(3);
const categoryInfo = site.categories[category];
---

<BaseLayout title={categoryInfo.label} description={categoryInfo.description}>
  <div class="container-page py-10">
    <div class="grid gap-6 lg:grid-cols-[minmax(0,7fr)_minmax(280px,3fr)]">
      <div class="space-y-6">
        <section class="panel p-6">
          <p class="chip mb-4 w-fit">Category</p>
          <h1 class="text-4xl font-black tracking-normal">{categoryInfo.label}</h1>
          <p class="mt-3 max-w-2xl text-[var(--color-muted)]">{categoryInfo.description}</p>
        </section>
        <section class="grid gap-4 xl:grid-cols-2">
          {posts.map((post) => <PostCard post={post} />)}
        </section>
      </div>
      <Sidebar projects={projects} />
    </div>
  </div>
</BaseLayout>
