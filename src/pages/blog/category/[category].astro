---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import PostCard from "@/components/PostCard.astro";
import Sidebar from "@/components/Sidebar.astro";
import { site, type CategoryKey } from "@/config/site";
import { categoryKeys, getFeaturedProjects, getPublishedPosts } from "@/lib/content";

export function getStaticPaths() {
  return categoryKeys.map((category) => ({ params: { category } }));
}

const category = Astro.params.category as CategoryKey;
const posts = (await getPublishedPosts()).filter((post) => post.data.category === category);
const projects = await getFeaturedProjects(3);
const categoryInfo = site.categories[category];
---

<BaseLayout title={categoryInfo.label} description={categoryInfo.description}>
  <div class="container-page page-wrap">
    <div class="page-layout">
      <section class="page-main-panel">
        <PageHero kicker="Category" title={categoryInfo.label} description={categoryInfo.description} />
        <div class="content-card-list">
          {posts.map((post) => <div class="content-row-card"><PostCard post={post} variant="row" /></div>)}
        </div>
      </section>
      <Sidebar projects={projects} />
    </div>
  </div>
</BaseLayout>
