---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import Sidebar from "@/components/Sidebar.astro";
import { site, type CategoryKey } from "@/config/site";
import { categoryKeys, getFeaturedProjects, getPublishedPosts } from "@/lib/content";

export function getStaticPaths() {
  return categoryKeys.map((category) => ({ params: { category } }));
}

const category = Astro.params.category as CategoryKey;
const posts = (await getPublishedPosts()).filter((post) => post.data.category === category);
const projects = await getFeaturedProjects(3);
const categoryInfo = site.categories[category];
---

<BaseLayout title={categoryInfo.label} description={categoryInfo.description}>
  <div class="container-page py-8 lg:py-10">
    <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_320px]">
      <section class="surface-main">
        <header class="surface-section">
          <p class="chip mb-4 w-fit">Category</p>
          <h1 class="text-4xl font-black tracking-normal sm:text-5xl">{categoryInfo.label}</h1>
          <p class="mt-4 max-w-3xl text-[15px] leading-8 text-[var(--color-muted)]">{categoryInfo.description}</p>
        </header>
        <div class="surface-divider content-list">
          {posts.map((post) => <div class="surface-section py-0"><PostCard post={post} variant="row" /></div>)}
        </div>
      </section>
      <Sidebar projects={projects} />
    </div>
  </div>
</BaseLayout>
