---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import Sidebar from "@/components/Sidebar.astro";
import { getAllTags, getFeaturedProjects, getPublishedPosts } from "@/lib/content";

export async function getStaticPaths() {
  const allPosts = await getPublishedPosts();
  const tags = getAllTags(allPosts);
  return tags.map((tag) => ({ params: { tag } }));
}

const allPosts = await getPublishedPosts();
const tag = Astro.params.tag ?? "";
const posts = allPosts.filter((post) => post.data.tags.includes(tag));
const projects = await getFeaturedProjects(3);
---

<BaseLayout title={`#${tag}`} description={`#${tag} 태그가 달린 글 목록입니다.`}>
  <div class="container-page py-10">
    <div class="grid gap-6 lg:grid-cols-[minmax(0,7fr)_minmax(280px,3fr)]">
      <div class="space-y-6">
        <section class="panel p-6">
          <p class="chip mb-4 w-fit">Tag</p>
          <h1 class="text-4xl font-black tracking-normal">#{tag}</h1>
          <p class="mt-3 text-[var(--color-muted)]">{posts.length}개의 글이 있습니다.</p>
        </section>
        <section class="grid gap-4 xl:grid-cols-2">
          {posts.map((post) => <PostCard post={post} />)}
        </section>
      </div>
      <Sidebar projects={projects} />
    </div>
  </div>
</BaseLayout>
