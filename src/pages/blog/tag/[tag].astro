---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import PostCard from "@/components/PostCard.astro";
import Sidebar from "@/components/Sidebar.astro";
import { getAllTags, getFeaturedProjects, getPublishedPosts } from "@/lib/content";

export async function getStaticPaths() {
  const allPosts = await getPublishedPosts();
  const tags = getAllTags(allPosts);
  return tags.map((tag) => ({ params: { tag } }));
}

const allPosts = await getPublishedPosts();
const tag = Astro.params.tag ?? "";
const posts = allPosts.filter((post) => post.data.tags.includes(tag));
const projects = await getFeaturedProjects(3);
---

<BaseLayout title={`#${tag}`} description={`#${tag} 태그가 달린 글 목록입니다.`}>
  <div class="container-page page-wrap">
    <div class="page-layout">
      <section class="page-main-panel">
        <PageHero kicker="Tag" title={`#${tag}`} description={`${posts.length}개의 글이 있습니다.`} />
        <div class="content-card-list">
          {posts.map((post) => <div class="content-row-card"><PostCard post={post} variant="row" /></div>)}
        </div>
      </section>
      <Sidebar projects={projects} />
    </div>
  </div>
</BaseLayout>
