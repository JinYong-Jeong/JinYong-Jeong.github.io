---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site } from "@/config/site";
---

<BaseLayout title="About" description={`${site.name}의 프로필과 실적입니다.`}>
  <div class="container-page py-10">
    <div class="grid gap-6 lg:grid-cols-[minmax(0,7fr)_minmax(280px,3fr)]">
      <section class="panel p-6 sm:p-8">
        <div class="flex flex-col gap-6 sm:flex-row sm:items-center">
          <img
            src={site.author.avatar}
            alt={`${site.author.displayName} avatar`}
            class="size-28 rounded-[2rem] border border-[var(--color-border)] object-cover"
            loading="lazy"
            referrerpolicy="no-referrer"
          />
          <div>
            <p class="chip mb-4 w-fit">Profile</p>
            <h1 class="text-4xl font-black tracking-normal sm:text-5xl">{site.name}</h1>
            <p class="mt-3 text-lg font-semibold text-[var(--color-accent)]">{site.author.role}</p>
            <p class="mt-4 max-w-3xl text-lg leading-9 text-[var(--color-muted)]">{site.author.longBio}</p>
          </div>
        </div>

        <div class="mt-8 grid gap-4 md:grid-cols-2">
          <div class="panel-subtle p-5">
            <h2 class="text-lg font-bold">관심 분야</h2>
            <ul class="mt-4 space-y-3 text-sm leading-7 text-[var(--color-muted)]">
              {site.focusAreas.map((area) => <li>· {area}</li>)}
            </ul>
          </div>
          <div class="panel-subtle p-5">
            <h2 class="text-lg font-bold">기술 스택</h2>
            <div class="mt-4 flex flex-wrap gap-2">
              {site.techStack.map((tech) => <span class="chip">{tech}</span>)}
            </div>
          </div>
        </div>

        <div class="mt-8 panel-subtle p-5">
          <h2 class="text-lg font-bold">실적</h2>
          <div class="mt-5 space-y-4">
            {
              site.achievements.map((achievement) => (
                <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-4">
                  <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
                    <p class="text-base font-semibold text-[var(--color-text)]">{achievement.title}</p>
                    <p class="text-sm font-medium text-[var(--color-accent)]">{achievement.period}</p>
                  </div>
                  <p class="mt-1 text-sm font-medium text-[var(--color-muted)]">{achievement.organization}</p>
                  <p class="mt-2 text-sm leading-7 text-[var(--color-muted)]">{achievement.note}</p>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <aside class="space-y-4 lg:sticky lg:top-24 lg:self-start">
        <section class="panel p-5">
          <h2 class="text-lg font-bold">Contact</h2>
          <div class="mt-4 space-y-2">
            {
              site.socials.map((link) => (
                <a class="focus-ring flex rounded-xl px-3 py-2 text-sm font-medium text-[var(--color-muted)] hover:bg-[var(--color-surface-soft)] hover:text-[var(--color-accent)]" href={link.href}>
                  {link.label}
                </a>
              ))
            }
          </div>
        </section>
        <section class="panel p-5">
          <h2 class="text-lg font-bold">Location</h2>
          <p class="mt-3 text-sm text-[var(--color-muted)]">{site.author.location}</p>
        </section>
      </aside>
    </div>
  </div>
</BaseLayout>
