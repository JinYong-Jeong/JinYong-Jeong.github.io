---
import CompactPostItem from "@/components/CompactPostItem.astro";
import HomeSidebar from "@/components/HomeSidebar.astro";
import HeroVisual from "@/components/HeroVisual.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site, type CategoryKey } from "@/config/site";
import { categoryKeys, getFeaturedProjects, getPublishedPosts } from "@/lib/content";

const posts = await getPublishedPosts();
const recentPosts = posts.slice(0, 2);
const featuredProjects = await getFeaturedProjects(3);
const homeCategories = categoryKeys.filter((category) => category !== "development");
---

<BaseLayout
  hideFooter={true}
  bodyClass="home-page"
  mainClass="home-main-shell"
  description="LLM, Federated Learning, 논문 리뷰, 실험 로그를 한눈에 정리한 연구 블로그입니다."
>
  <section class="container-page home-screen py-4 lg:py-5">
    <section class="home-stage" aria-label="Homepage overview">
      <div class="home-grid">
        <div class="home-primary">
          <header class="home-hero">
            <div class="home-copy min-w-0">
              <p class="chip mb-5 w-fit">{site.author.role}</p>
              <h1 class="home-title hero-title max-w-3xl font-black tracking-normal text-[var(--color-text)]">
                실험하고, 기록하고, 공유합니다.
              </h1>
              <p class="hero-copy home-lead mt-5 max-w-2xl text-[var(--color-muted)]">
                LLM, Federated Learning, 논문 리뷰, 실험 로그를 다시 구현하고
                검증할 수 있는 연구 기록으로 정리합니다.
              </p>
              <dl class="home-stats" aria-label="Blog metrics">
                <div class="home-stat">
                  <dt>Archive</dt>
                  <dd>{posts.length}</dd>
                </div>
                <div class="home-stat">
                  <dt>Projects</dt>
                  <dd>{featuredProjects.length}</dd>
                </div>
                <div class="home-stat">
                  <dt>Tracks</dt>
                  <dd>{site.focusAreas.length}</dd>
                </div>
              </dl>
              <nav class="mt-8 flex flex-wrap gap-3" aria-label="Homepage primary actions">
                <a
                  class="focus-ring rounded-xl bg-[var(--color-accent)] px-4 py-2.5 font-semibold text-white shadow-[var(--shadow-card)] hover:bg-[#59331f]"
                  href="/blog/"
                >
                  최근 글 읽기
                </a>
                <a
                  class="focus-ring rounded-xl border border-[var(--color-border-strong)] px-4 py-2.5 font-semibold text-[var(--color-accent)] hover:bg-[var(--color-surface-soft)]"
                  href="/search/"
                >
                  아카이브 검색
                </a>
              </nav>
            </div>
            <HeroVisual compact={true} />
          </header>

          <div class="home-library">
            <section class="home-section" aria-labelledby="recent-notes-heading">
              <header class="home-section-heading">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.1em] text-[var(--color-subtle)]">Archive</p>
                  <h2 id="recent-notes-heading" class="mt-1 text-xl font-semibold tracking-normal text-[var(--color-text)]">
                    Recent Notes
                  </h2>
                </div>
                <a class="focus-ring text-sm font-semibold text-[var(--color-accent)] hover:underline" href="/blog/">
                  전체 글 보기
                </a>
              </header>
              <ol class="home-post-list">
                {recentPosts.map((post) => <li><CompactPostItem post={post} /></li>)}
              </ol>
            </section>

            <section class="home-section" aria-labelledby="research-track-heading">
              <header class="home-section-heading">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.1em] text-[var(--color-subtle)]">Overview</p>
                  <h2 id="research-track-heading" class="mt-1 text-xl font-semibold tracking-normal text-[var(--color-text)]">
                    Search & Tracks
                  </h2>
                </div>
                <a class="focus-ring text-sm font-semibold text-[var(--color-accent)] hover:underline" href="/search/">
                  검색 열기
                </a>
              </header>

              <form action="/search/" class="home-search-form">
                <label class="sr-only" for="home-search-input">검색어</label>
                <input
                  id="home-search-input"
                  name="q"
                  type="search"
                  placeholder="LoRA, Flower, quantization"
                  class="home-search-input"
                />
                <button class="focus-ring home-search-button" type="submit">찾기</button>
              </form>

              <nav class="home-track-list" aria-label="Research categories">
                {
                  homeCategories.map((category) => (
                    <a class="home-track-item" href={`/blog/category/${category}/`}>
                      <span class="home-track-label">
                        {site.categories[category as CategoryKey].label}
                      </span>
                      <span class="home-track-description">
                        {site.categories[category as CategoryKey].description}
                      </span>
                    </a>
                  ))
                }
              </nav>
            </section>
          </div>
        </div>

        <HomeSidebar projects={featuredProjects} />
      </div>
    </section>
  </section>
</BaseLayout>
