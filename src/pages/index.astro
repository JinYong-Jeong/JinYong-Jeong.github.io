---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import Sidebar from "@/components/Sidebar.astro";
import { site } from "@/config/site";
import { getFeaturedProjects, getPublishedPosts } from "@/lib/content";
import {
  ArrowRight,
  BookOpenText,
  BrainCircuit,
  Cpu,
  FolderKanban,
  Network,
  PenLine
} from "@lucide/astro";
import bgImage from "../../engineering/design/bg.png";

const posts = await getPublishedPosts();
const recentPosts = posts.slice(0, 3);
const featuredProjects = await getFeaturedProjects(3);
const heroImage = typeof bgImage === "string" ? bgImage : bgImage.src;
const topics = [
  { label: "LLM", icon: BrainCircuit },
  { label: "Federated Learning", icon: Network },
  { label: "NLP", icon: BookOpenText },
  { label: "Deep Learning", icon: Cpu },
  { label: "MLOps", icon: PenLine }
];
---

<BaseLayout bodyClass="home-page" mainClass="home-main">
  <div class="container-page home-wrap">
    <div class="home-layout">
      <section class="home-content-panel">
        <header class="home-hero" style={`--hero-bg: url(${heroImage});`}>
          <div class="home-hero-content">
            <p class="home-eyebrow">{site.author.role}</p>
            <h1 class="home-title">
              Research. Build.
              <br />
              Learn. Share.
            </h1>
            <p class="home-copy">
              LLM과 Federated Learning을 중심으로 연구하고, 실험을 기록하며,
              배운 것을 재현 가능한 노트로 공유합니다.
            </p>
            <div class="home-actions">
              <a class="home-button home-button-primary focus-ring" href="/blog/">
                최근 글 보기
                <ArrowRight size={18} stroke-width={1.8} />
              </a>
              <a class="home-button home-button-secondary focus-ring" href="/projects/">
                프로젝트 보기
              </a>
            </div>
            <div class="home-topic-row" aria-label="Focus topics">
              {
                topics.map((topic) => {
                  const Icon = topic.icon;
                  return (
                    <span class="home-topic-pill">
                      <Icon size={16} stroke-width={1.8} />
                      {topic.label}
                    </span>
                  );
                })
              }
            </div>
          </div>
        </header>

        <section class="home-section-block">
          <div class="home-section-heading">
            <div class="home-section-title">
              <BookOpenText size={20} stroke-width={1.8} />
              <h2>Latest Posts</h2>
            </div>
            <a class="home-inline-link focus-ring" href="/blog/">모든 글 보기 <ArrowRight size={16} /></a>
          </div>
          <div class="home-card-grid">
            {
              recentPosts.map((post) => (
                <div class="home-card">
                  <PostCard post={post} />
                </div>
              ))
            }
          </div>
        </section>

        <section class="home-section-block home-section-tight">
          <div class="home-section-heading">
            <div class="home-section-title">
              <FolderKanban size={20} stroke-width={1.8} />
              <h2>Featured Projects</h2>
            </div>
            <a class="home-inline-link focus-ring" href="/projects/">모든 프로젝트 보기 <ArrowRight size={16} /></a>
          </div>
          <div class="home-project-grid">
            {
              featuredProjects.map((project) => (
                <div class="home-card home-project-card">
                  <ProjectCard project={project} />
                </div>
              ))
            }
          </div>
        </section>
      </section>

      <Sidebar projects={featuredProjects} variant="home" />
    </div>
  </div>
</BaseLayout>
