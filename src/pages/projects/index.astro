---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import Sidebar from "@/components/Sidebar.astro";
import { getAllProjects, getFeaturedProjects } from "@/lib/content";

const projects = await getAllProjects();
const sidebarProjects = await getFeaturedProjects(3);
---

<BaseLayout title="Projects" description="LLM, Federated Learning, evaluation, 실험 로깅 프로젝트 목록입니다.">
  <div class="container-page page-wrap">
    <div class="page-layout">
      <section class="page-main-panel">
        <PageHero
          kicker="Build Log"
          title="Projects"
          description="연구 아이디어를 실제 코드와 도구로 옮긴 작업을 정리합니다."
        />

        <div class="page-toolbar">
          <label class="block">
            <span class="sr-only">프로젝트 검색</span>
            <input
              id="project-search"
              type="search"
              placeholder="제목, 설명, 기술 스택 검색"
              class="page-search-input"
            />
          </label>
          <a class="page-toolbar-link focus-ring" href="/search/">
            전체 검색 페이지 →
          </a>
        </div>
        <p id="project-search-summary" class="page-result-summary">
          {projects.length}개의 프로젝트 기록
        </p>

        <div id="project-list" class="content-card-list">
        {
          projects.map((project) => (
            <div
              class="content-row-card"
              data-project-row
              data-search={`${project.data.title} ${project.data.description} ${project.data.status} ${project.data.techStack.join(" ")}`.toLowerCase()}
            >
              <ProjectCard project={project} variant="row" />
            </div>
          ))
        }
        </div>
        <div id="project-empty" class="hidden page-empty-state">
          일치하는 프로젝트가 없습니다. 다른 키워드로 다시 검색해보세요.
        </div>
      </section>

      <Sidebar projects={sidebarProjects} />
    </div>
  </div>

  <script is:inline>
    const params = new URLSearchParams(window.location.search);
    const initialQuery = params.get("q") || "";
    const input = document.querySelector("#project-search");
    const summary = document.querySelector("#project-search-summary");
    const emptyState = document.querySelector("#project-empty");
    const rows = Array.from(document.querySelectorAll("[data-project-row]"));

    if (input) input.value = initialQuery;

    const update = () => {
      const query = String(input?.value || "").trim().toLowerCase();
      let visible = 0;

      for (const row of rows) {
        const text = row.getAttribute("data-search") || "";
        const match = !query || text.includes(query);
        row.toggleAttribute("hidden", !match);
        if (match) visible += 1;
      }

      if (summary) {
        summary.textContent = query
          ? `"${query}" 검색 결과 ${visible}개`
          : `${rows.length}개의 프로젝트 기록`;
      }

      emptyState?.classList.toggle("hidden", visible !== 0);
    };

    input?.addEventListener("input", update);
    update();
  </script>
</BaseLayout>
