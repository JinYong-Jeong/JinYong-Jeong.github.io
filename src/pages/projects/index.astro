---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { getAllProjects } from "@/lib/content";

const projects = await getAllProjects();
---

<BaseLayout title="Projects" description="LLM, Federated Learning, evaluation, 실험 로깅 프로젝트 목록입니다.">
  <div class="container-page py-10">
    <section class="panel mb-6 p-6">
      <p class="chip mb-4 w-fit">Build Log</p>
      <h1 class="text-4xl font-black tracking-normal">Projects</h1>
      <p class="mt-3 max-w-2xl text-[var(--color-muted)]">
        연구 아이디어를 실제 코드와 도구로 옮긴 작업을 정리합니다.
      </p>
      <div class="mt-6 grid gap-3 sm:grid-cols-3">
        <div class="panel-subtle p-4">
          <p class="text-xs uppercase tracking-[0.08em] text-[var(--color-subtle)]">Focus</p>
          <p class="mt-2 text-xl font-black text-[var(--color-accent)]">FedLLM</p>
          <p class="mt-1 text-sm text-[var(--color-muted)]">연합학습 기반 LLM 실험</p>
        </div>
        <div class="panel-subtle p-4">
          <p class="text-xs uppercase tracking-[0.08em] text-[var(--color-subtle)]">Tooling</p>
          <p class="mt-2 text-xl font-black text-[var(--color-accent)]">Evaluation</p>
          <p class="mt-1 text-sm text-[var(--color-muted)]">자동 평가와 로그 수집</p>
        </div>
        <div class="panel-subtle p-4">
          <p class="text-xs uppercase tracking-[0.08em] text-[var(--color-subtle)]">Artifacts</p>
          <p class="mt-2 text-xl font-black text-[var(--color-accent)]">{projects.length}</p>
          <p class="mt-1 text-sm text-[var(--color-muted)]">정리된 프로젝트 카드</p>
        </div>
      </div>
    </section>
    <section class="grid gap-4 lg:grid-cols-2">
      {projects.map((project) => <ProjectCard project={project} />)}
    </section>
  </div>
</BaseLayout>
